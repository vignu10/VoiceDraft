{
  "name": "voicescribe-monorepo",
  "version": "1.0.0",
  "scripts": {
    "dev:web": "cd web && npm run dev",
    "dev:mobile": "cd mobile-app && expo start",
    "build:web": "cd web && npm run build",
    "build:mobile": "cd mobile-app && expo build",
    "install:all": "npm install && cd web && npm install && cd ../mobile-app && npm install",
    "start": "npm run dev:mobile",
    "api": "node server.js",
    "android": "npm run dev:mobile -- --android",
    "ios": "npm run dev:mobile -- --ios",
    "typecheck": "npm run typecheck:web && npm run typecheck:mobile",
    "typecheck:web": "cd web && tsc --noEmit",
    "typecheck:mobile": "cd mobile-app && tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/core": "^7.14.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.90.20",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-audio": "^1.1.1",
    "expo-av": "~16.0.8",
    "expo-blur": "^15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "^55.0.13",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "openai": "^6.17.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-audio-visualizer": "^0.0.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@napi-rs/canvas": "^0.1.97",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/json5": "^0.0.30",
    "@types/react": "~19.1.0",
    "@types/uuid": "^10.0.0",
