    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "postcss": "^8.5.8",
    "svg2img": "^1.0.0-beta.2",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.0"
  },
  "private": true
}
