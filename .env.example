# OpenAI API Key (required for transcription and blog generation)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Upstash Redis Configuration (required for job queue infrastructure)
# Get your credentials from: https://upstash.com/console
# Create a new Redis database and copy the REST API URL and token
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token-here

# API URL for Expo app (use your machine's IP for mobile device access)
EXPO_PUBLIC_API_URL=http://YOUR_IP_ADDRESS:3000
