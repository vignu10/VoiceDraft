# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ========== MONOREPO ROOT ==========
# Workspace dependencies (if any)
node_modules/

# ========== MOBILE APP ==========
# Mobile app dependencies
mobile-app/node_modules/

# Expo
mobile-app/.expo/
mobile-app/dist/
mobile-app/web-build/
mobile-app/expo-env.d.ts

# Native
mobile-app/.kotlin/
mobile-app/*.orig.*
mobile-app/*.jks
mobile-app/*.p8
mobile-app/*.p12
mobile-app/*.key
mobile-app/*.mobileprovision

# Metro
mobile-app/.metro-health-check*

# debug
mobile-app/npm-debug.*
mobile-app/yarn-debug.*
mobile-app/yarn-error.*

# macOS
mobile-app/.DS_Store
mobile-app/*.pem

# local env files (keep .env.example)
mobile-app/.env
mobile-app/.env*.local

# TypeScript
mobile-app/*.tsbuildinfo

# bugreports
mobile-app/bugreport-*.zip

# generated native folders
mobile-app/ios/
mobile-app/android/

# ========== BACKEND ==========
# Backend dependencies
backend/node_modules/

# Backend logs
backend/server.log
backend/*.log

# Backend uploads (local storage)
backend/uploads/
backend/uploads/*

# Backend env files (keep .env.example)
backend/.env
backend/.env*.local

# ========== COMMON ==========
# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
